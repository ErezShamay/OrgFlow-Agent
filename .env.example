# ElayoAI (OrgFlow) — Backend environment configuration
#
# Copy this file to .env and fill in the values for your environment.
# The authoritative list of variables (defaults, validation rules) lives in
# app/config/settings.py — treat that file as the source of truth if this
# example ever drifts out of sync.

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------

# local | development | staging | production | test
ENVIRONMENT=local

FRONTEND_URL=http://localhost:3000

# Extra CORS origins beyond FRONTEND_URL, comma-separated (optional)
# CORS_EXTRA_ORIGINS=https://staging.example.com,https://preview.example.com

LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# AI / LLM
# ---------------------------------------------------------------------------

# ollama | openai | anthropic | gemini
AI_PROVIDER=ollama
# Comma-separated fallback chain, e.g. "openai,anthropic" (optional)
# AI_FALLBACK_PROVIDERS=

DEFAULT_AI_MODEL=mistral
AI_MAX_RETRIES=2

# mock | openai — controls the internal agent's LLM adapter, independent of
# AI_PROVIDER above (which drives the AI review/assignment feature layer)
ORG_FLOW_LLM_MODE=mock

OPENAI_MODEL=gpt-5.5
OPENAI_API_KEY=
# Optional key ring for rotation, comma-separated
# OPENAI_API_KEYS=
# OPENAI_ACTIVE_KEY_INDEX=0

ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Supabase (required together, or leave both empty for local/test)
# ---------------------------------------------------------------------------

SUPABASE_URL=
# Must be the service_role secret (Project Settings → API), not anon/public
SUPABASE_KEY=

# ---------------------------------------------------------------------------
# Email
# ---------------------------------------------------------------------------

# gmail | microsoft
EMAIL_PROVIDER=gmail
RESEND_API_KEY=

# ---------------------------------------------------------------------------
# Auth (JWT)
# ---------------------------------------------------------------------------

# In staging/production this MUST be overridden with a real random secret of
# at least 32 characters — app/config/settings.py refuses to boot with the
# committed dev default in those environments.
AUTH_JWT_SECRET=dev-secret-change-me-at-least-32-chars
AUTH_JWT_ALGORITHM=HS256
AUTH_SESSION_TIMEOUT_MINUTES=60
AUTH_REFRESH_TOKEN_TTL_MINUTES=1440

# ---------------------------------------------------------------------------
# Idempotency / DB retry / config cache
# ---------------------------------------------------------------------------

CONFIG_CACHE_TTL_SECONDS=60
IDEMPOTENCY_TTL_SECONDS=3600
IDEMPOTENCY_HEADER=X-Idempotency-Key
DB_RETRY_MAX_ATTEMPTS=3
DB_RETRY_BASE_DELAY_SECONDS=0.1
DB_OPERATION_TIMEOUT_SECONDS=5.0

# ---------------------------------------------------------------------------
# Feature flags (any truthy value: 1/true/yes/on)
# ---------------------------------------------------------------------------

FEATURE_NOTIFICATIONS=true
FEATURE_AUTOMATION=true
FEATURE_AI_REVIEW=true
FEATURE_EMAIL_DELIVERY=true
