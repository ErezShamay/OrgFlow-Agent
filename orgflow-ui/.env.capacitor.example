# ElayoAI Field Reports - APK / Capacitor (FR-034)
# העתק ל-.env.capacitor.local (לא ב-git) לפני:
#   npm run cap:apk:debug
#   npm run android:apk

# API - כתובת השרת (FastAPI / auth/exchange), נקלעת ל-bundle
# אמולטור Android (FastAPI על המחשב):
NEXT_PUBLIC_API_URL=http://10.0.2.2:8000
# מכשיר פיזי (Wi‑Fi) - IP של המחשב, אותו פורט שבו רץ uvicorn (0.0.0.0:8000):
# NEXT_PUBLIC_API_URL=http://192.168.1.10:8000
# אופציונלי - דורס רק ב-APK:
# NEXT_PUBLIC_API_URL_ANDROID=http://192.168.1.10:3000

# Supabase (חובה להתחברות)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# גרסת APK
ELAYOAI_ANDROID_VERSION_CODE=1
ELAYOAI_ANDROID_VERSION_NAME=1.0.0

# --- אופציונלי: Build A (WebView טוען את Next ב-dev) ---
# ELAYOAI_CAPACITOR_BUILD_MODE=url
# ELAYOAI_CAPACITOR_SERVER_URL=http://10.0.2.2:3000
# ELAYOAI_CAPACITOR_ALLOW_CLEARTEXT=1
