# OrgFlow — Preview בענן (Vercel + Render + Supabase)
# העתק ערכים ל-Render (API) ול-Vercel (UI). אל תעלה קובץ זה עם סודות ל-Git.

# --- Render (Backend) ---
ENVIRONMENT=staging
FRONTEND_URL=https://YOUR_APP.vercel.app
# מופרדים בפסיק; שימושי ל-preview deployments של Vercel
CORS_EXTRA_ORIGINS=https://YOUR_APP.vercel.app,https://YOUR_APP-git-main-YOU.vercel.app

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

AUTH_JWT_SECRET=generate-a-random-string-at-least-32-chars

ORG_FLOW_LLM_MODE=mock
AI_PROVIDER=openai
DEFAULT_AI_MODEL=gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
AI_MAX_RETRIES=2
LOG_LEVEL=WARNING
EMAIL_PROVIDER=gmail

FEATURE_AI_REVIEW=false
FEATURE_AUTOMATION=false
FEATURE_EMAIL_DELIVERY=false
FEATURE_NOTIFICATIONS=false

# --- Vercel (Frontend) — Environment Variables ---
# אותו Project URL כמו SUPABASE_URL למעלה, שם שונה (חובה NEXT_PUBLIC_ לדפדפן):
# NEXT_PUBLIC_API_URL=https://orgflow-api.onrender.com
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon מ-Supabase API, לא SUPABASE_KEY>
# NEXT_PUBLIC_FORCE_LOGIN=false
