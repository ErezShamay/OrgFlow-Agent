ENVIRONMENT=staging
FRONTEND_URL=https://staging.orgflow.example.com
SUPABASE_URL=https://your-staging-project.supabase.co
# service_role secret from Supabase → Project Settings → API (not the anon key)
SUPABASE_KEY=your-staging-supabase-service-role-key
AUTH_JWT_SECRET=staging-jwt-secret-at-least-32-chars
OPENAI_API_KEY=sk-your-staging-key
LOG_LEVEL=INFO
AI_PROVIDER=openai
DEFAULT_AI_MODEL=gpt-4o
AI_MAX_RETRIES=3
ORG_FLOW_LLM_MODE=openai
OPENAI_MODEL=gpt-4o
EMAIL_PROVIDER=gmail
