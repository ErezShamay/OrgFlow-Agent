{
  "uid": "orgflow-overview",
  "title": "OrgFlow Overview",
  "tags": ["orgflow", "overview"],
  "timezone": "browser",
  "panels": [
    {
      "title": "Request Rate",
      "type": "graph",
      "targets": [{"expr": "rate(http_requests_total[5m])"}]
    },
    {
      "title": "Error Rate",
      "type": "graph",
      "targets": [{"expr": "rate(http_request_errors_total[5m])"}]
    },
    {
      "title": "P95 Latency",
      "type": "graph",
      "targets": [{"expr": "histogram_quantile(0.95, http_request_duration_seconds)"}]
    }
  ]
}
